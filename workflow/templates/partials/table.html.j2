{% if table.has_controls %}
<div class="table-controls">
  {% if table.search %}
  <input class="table-search" data-search="{{ table.table_id }}" placeholder="Search {{ table.table_id.replace('-', ' ') }}...">
  {% endif %}
  {% for filter in table.filters %}
  <label class="filter-label">{{ filter.label }}
    <select data-filter="{{ table.table_id }}" data-column="{{ filter.column_index }}">
      <option value="">All</option>
      {% for value in filter.options %}
      <option value="{{ value }}">{{ value }}</option>
      {% endfor %}
    </select>
  </label>
  {% endfor %}
</div>
{% endif %}

{% if table.rows and table.columns %}
<div class="table-wrap">
  <table id="{{ table.table_id }}" class="data-table">
    <thead>
      <tr>
        {% for column in table.columns %}
        <th>{{ column }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in table.rows %}
      <tr>
        {% for cell in row %}
        <td>{{ cell | safe }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<p class="muted">{{ table.empty_message }}</p>
{% endif %}

