from pathlib import Path
import json
import re
import shlex
import sys


REPO_ROOT = Path(workflow.basedir).resolve().parent


configfile: str(REPO_ROOT / "config.yml")


if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from workflow.lib.common import normalize_workflow_config
from workflow.lib.layout import get_experiment_layout_paths


WORKFLOW_CONFIG = normalize_workflow_config(
    config,
    llvm_tag_override=config.get("llvm_tag_override"),
)
BASE_DIR = Path(WORKFLOW_CONFIG["project"]["base_dir"]).expanduser().resolve()
EXPERIMENTS = WORKFLOW_CONFIG["experiments"]
EXPERIMENTS_BY_ID = {experiment["experiment_id"]: experiment for experiment in EXPERIMENTS}
EXPERIMENT_ID_PATTERN = "|".join(re.escape(experiment["experiment_id"]) for experiment in EXPERIMENTS)
EXPERIMENT_LAYOUTS = {
    experiment["experiment_id"]: get_experiment_layout_paths(BASE_DIR, experiment)
    for experiment in EXPERIMENTS
}
EXCLUSIVE_BENCHMARK_THREADS = 9999

ANALYSIS_REPORT = str(BASE_DIR / "reports" / "analysis_report.html")
METADATA_OUTPUTS = [
    str(EXPERIMENT_LAYOUTS[experiment["experiment_id"]]["metadata_run_dir"] / "experiment.json")
    for experiment in EXPERIMENTS
]
CURRENT_PARSED = [
    str(EXPERIMENT_LAYOUTS[experiment["experiment_id"]]["parsed_run_dir"] / "benchmark_records.csv")
    for experiment in EXPERIMENTS
]
HISTORICAL_PARSED = [
    str(path)
    for path in sorted((BASE_DIR / "parsed").glob("*/benchmark_records.csv"))
]
ANALYSIS_INPUTS = sorted(set(CURRENT_PARSED).union(HISTORICAL_PARSED))
ANALYSIS_DIR = BASE_DIR / "analysis"
ANALYSIS_OUTPUTS = {
    "analysis_records": str(ANALYSIS_DIR / "analysis_records.csv"),
    "sample_statistics": str(ANALYSIS_DIR / "sample_statistics.csv"),
    "metric_comparisons": str(ANALYSIS_DIR / "metric_comparisons.csv"),
    "top_regressions": str(ANALYSIS_DIR / "top_regressions.csv"),
    "top_improvements": str(ANALYSIS_DIR / "top_improvements.csv"),
    "analysis_summary": str(ANALYSIS_DIR / "analysis_summary.json"),
}

LLVM_TAGS = sorted({str(experiment["llvm_tag"]) for experiment in EXPERIMENTS})
OFFICIAL_TAGS = sorted({str(experiment["official_tag"]) for experiment in EXPERIMENTS})
RAJA_TAGS = sorted({str(experiment["raja_tag"]) for experiment in EXPERIMENTS})


def experiment_from_wildcards(wildcards):
    return EXPERIMENTS_BY_ID[wildcards.experiment_id]


def layout_from_experiment_id(experiment_id):
    return EXPERIMENT_LAYOUTS[experiment_id]


rule all:
    input:
        ANALYSIS_REPORT,
        METADATA_OUTPUTS,


wildcard_constraints:
    experiment_id=EXPERIMENT_ID_PATTERN,


rule checkout_llvm:
    output:
        source_dir=directory(str(BASE_DIR / "sources" / "llvm-project" / "{llvm_tag}")),
        stamp=str(BASE_DIR / "sources" / "llvm-project" / "{llvm_tag}" / ".checkout_complete"),
    log:
        str(BASE_DIR / "logs" / "_shared" / "checkout_llvm" / "{llvm_tag}" / "checkout_llvm.log"),
    params:
        repo_url=WORKFLOW_CONFIG["llvm"]["repo_url"],
        tag_or_branch=lambda wildcards: wildcards.llvm_tag,
    script:
        "scripts/checkout_repo.py"


rule checkout_official:
    output:
        source_dir=directory(str(BASE_DIR / "sources" / "official" / "{official_tag}")),
        stamp=str(BASE_DIR / "sources" / "official" / "{official_tag}" / ".checkout_complete"),
    log:
        str(BASE_DIR / "logs" / "_shared" / "checkout_official" / "{official_tag}" / "checkout_official.log"),
    params:
        repo_url=WORKFLOW_CONFIG["test_suite"]["official"]["repo_url"],
        tag_or_branch=lambda wildcards: wildcards.official_tag,
        recursive=False,
    script:
        "scripts/checkout_repo.py"


rule checkout_raja:
    output:
        source_dir=directory(str(BASE_DIR / "sources" / "raja" / "{raja_tag}")),
        stamp=str(BASE_DIR / "sources" / "raja" / "{raja_tag}" / ".checkout_complete"),
    log:
        str(BASE_DIR / "logs" / "_shared" / "checkout_raja" / "{raja_tag}" / "checkout_raja.log"),
    params:
        repo_url=WORKFLOW_CONFIG["test_suite"]["raja"]["repo_url"],
        tag_or_branch=lambda wildcards: wildcards.raja_tag,
        recursive=True,
    script:
        "scripts/checkout_repo.py"


rule build_llvm:
    input:
        checkout_stamp=str(BASE_DIR / "sources" / "llvm-project" / "{llvm_tag}" / ".checkout_complete"),
    output:
        clangxx=str(BASE_DIR / "installs" / "llvm" / "{llvm_tag}" / "bin" / "clang++"),
        stamp=str(BASE_DIR / "builds" / "llvm" / "{llvm_tag}" / ".build_complete"),
    log:
        str(BASE_DIR / "logs" / "_shared" / "build_llvm" / "{llvm_tag}" / "build_llvm.log"),
    params:
        source_dir=lambda wildcards: str(BASE_DIR / "sources" / "llvm-project" / wildcards.llvm_tag),
        build_dir=lambda wildcards: str(BASE_DIR / "builds" / "llvm" / wildcards.llvm_tag),
        install_dir=lambda wildcards: str(BASE_DIR / "installs" / "llvm" / wildcards.llvm_tag),
        host_c_compiler=WORKFLOW_CONFIG["llvm"]["build"]["c_compiler"],
        host_cxx_compiler=WORKFLOW_CONFIG["llvm"]["build"]["cxx_compiler"],
        ninja_jobs=WORKFLOW_CONFIG["build"]["ninja_jobs"],
        clean_build=WORKFLOW_CONFIG["build"]["clean_build"],
        reconfigure=WORKFLOW_CONFIG["build"]["reconfigure"],
    script:
        "scripts/build_llvm.py"


rule build_official:
    input:
        checkout_stamp=str(BASE_DIR / "sources" / "official" / "{official_tag}" / ".checkout_complete"),
        llvm_clangxx=str(BASE_DIR / "installs" / "llvm" / "{llvm_tag}" / "bin" / "clang++"),
        llvm_stamp=str(BASE_DIR / "builds" / "llvm" / "{llvm_tag}" / ".build_complete"),
    output:
        cache=str(BASE_DIR / "builds" / "official" / "{official_tag}" / "llvm-{llvm_tag}" / "CMakeCache.txt"),
        stamp=str(BASE_DIR / "builds" / "official" / "{official_tag}" / "llvm-{llvm_tag}" / ".build_complete"),
    log:
        str(
            BASE_DIR / "logs" / "_shared" / "build_official" / "{official_tag}" / "llvm-{llvm_tag}" / "build_official.log"
        ),
    params:
        source_dir=lambda wildcards: str(BASE_DIR / "sources" / "official" / wildcards.official_tag),
        build_dir=lambda wildcards: str(
            BASE_DIR / "builds" / "official" / wildcards.official_tag / f"llvm-{wildcards.llvm_tag}"
        ),
        llvm_install_dir=lambda wildcards: str(BASE_DIR / "installs" / "llvm" / wildcards.llvm_tag),
        cxx_standard=WORKFLOW_CONFIG["test_suite"]["official"]["cxx_standard"],
        ninja_jobs=WORKFLOW_CONFIG["build"]["ninja_jobs"],
        clean_build=WORKFLOW_CONFIG["build"]["clean_build"],
        reconfigure=WORKFLOW_CONFIG["build"]["reconfigure"],
    script:
        "scripts/build_official.py"


rule build_raja:
    input:
        checkout_stamp=str(BASE_DIR / "sources" / "raja" / "{raja_tag}" / ".checkout_complete"),
        llvm_clangxx=str(BASE_DIR / "installs" / "llvm" / "{llvm_tag}" / "bin" / "clang++"),
        llvm_stamp=str(BASE_DIR / "builds" / "llvm" / "{llvm_tag}" / ".build_complete"),
    output:
        exe=str(BASE_DIR / "builds" / "raja" / "{raja_tag}" / "llvm-{llvm_tag}" / "bin" / "raja-perf.exe"),
        stamp=str(BASE_DIR / "builds" / "raja" / "{raja_tag}" / "llvm-{llvm_tag}" / ".build_complete"),
    log:
        str(BASE_DIR / "logs" / "_shared" / "build_raja" / "{raja_tag}" / "llvm-{llvm_tag}" / "build_raja.log"),
    params:
        source_dir=lambda wildcards: str(BASE_DIR / "sources" / "raja" / wildcards.raja_tag),
        build_dir=lambda wildcards: str(BASE_DIR / "builds" / "raja" / wildcards.raja_tag / f"llvm-{wildcards.llvm_tag}"),
        llvm_install_dir=lambda wildcards: str(BASE_DIR / "installs" / "llvm" / wildcards.llvm_tag),
        cxx_standard=WORKFLOW_CONFIG["test_suite"]["raja"]["cxx_standard"],
        ninja_jobs=WORKFLOW_CONFIG["build"]["ninja_jobs"],
        clean_build=WORKFLOW_CONFIG["build"]["clean_build"],
        reconfigure=WORKFLOW_CONFIG["build"]["reconfigure"],
    script:
        "scripts/build_raja.py"


rule run_official:
    input:
        build_stamp=str(BASE_DIR / "builds" / "official" / "{official_tag}" / "llvm-{llvm_tag}" / ".build_complete"),
        llvm_clangxx=str(BASE_DIR / "installs" / "llvm" / "{llvm_tag}" / "bin" / "clang++"),
    output:
        results=str(BASE_DIR / "results" / "official-{official_tag}" / "{llvm_tag}" / "{label}" / "{sample}" / "baseline_results.json"),
        stamp=str(BASE_DIR / "results" / "official-{official_tag}" / "{llvm_tag}" / "{label}" / "{sample}" / ".run_complete"),
    log:
        str(BASE_DIR / "logs" / "_runs" / "official" / "{official_tag}" / "{llvm_tag}" / "{label}" / "{sample}" / "run_official.log"),
    threads:
        EXCLUSIVE_BENCHMARK_THREADS
    params:
        build_dir=lambda wildcards: str(BASE_DIR / "builds" / "official" / wildcards.official_tag / f"llvm-{wildcards.llvm_tag}"),
        lit_args=WORKFLOW_CONFIG["test_selection"]["official"]["resolved_lit_args"],
        sample=lambda wildcards: wildcards.sample,
    script:
        "scripts/run_official.py"


rule run_raja:
    input:
        build_stamp=str(BASE_DIR / "builds" / "raja" / "{raja_tag}" / "llvm-{llvm_tag}" / ".build_complete"),
        exe=str(BASE_DIR / "builds" / "raja" / "{raja_tag}" / "llvm-{llvm_tag}" / "bin" / "raja-perf.exe"),
    output:
        stamp=str(BASE_DIR / "results" / "raja-{raja_tag}" / "{llvm_tag}" / "{label}" / "{sample}" / ".run_complete"),
    log:
        str(BASE_DIR / "logs" / "_runs" / "raja" / "{raja_tag}" / "{llvm_tag}" / "{label}" / "{sample}" / "run_raja.log"),
    threads:
        EXCLUSIVE_BENCHMARK_THREADS
    params:
        exe=lambda wildcards: str(BASE_DIR / "builds" / "raja" / wildcards.raja_tag / f"llvm-{wildcards.llvm_tag}" / "bin" / "raja-perf.exe"),
        result_dir=lambda wildcards: str(BASE_DIR / "results" / f"raja-{wildcards.raja_tag}" / wildcards.llvm_tag / wildcards.label / wildcards.sample),
        extra_args=WORKFLOW_CONFIG["test_selection"]["raja"]["resolved_extra_args"],
        sample=lambda wildcards: wildcards.sample,
    script:
        "scripts/run_raja.py"


rule parse_results:
    input:
        official_results=lambda wildcards: str(
            layout_from_experiment_id(wildcards.experiment_id)["official_result"] / "baseline_results.json"
        ),
        official_stamp=lambda wildcards: str(
            layout_from_experiment_id(wildcards.experiment_id)["official_result"] / ".run_complete"
        ),
        raja_stamp=lambda wildcards: str(
            layout_from_experiment_id(wildcards.experiment_id)["raja_result"] / ".run_complete"
        ),
    output:
        parsed_csv=str(BASE_DIR / "parsed" / "{experiment_id}" / "benchmark_records.csv"),
    log:
        str(BASE_DIR / "logs" / "{experiment_id}" / "parse_results.log"),
    params:
        input_dir=str(BASE_DIR / "results"),
        label=lambda wildcards: experiment_from_wildcards(wildcards)["label"],
        sample=lambda wildcards: experiment_from_wildcards(wildcards)["sample"],
        compiler_version=lambda wildcards: experiment_from_wildcards(wildcards)["llvm_tag"],
        official_tag=lambda wildcards: experiment_from_wildcards(wildcards)["official_tag"],
        raja_tag=lambda wildcards: experiment_from_wildcards(wildcards)["raja_tag"],
    shell:
        ".venv/bin/python workflow/scripts/parse_results_cli.py "
        "--input-dir {params.input_dir} "
        "--label {params.label} "
        "--sample {params.sample} "
        "--compiler-version {params.compiler_version} "
        "--suite-version official={params.official_tag} "
        "--suite-version raja={params.raja_tag} "
        "--output-file {output.parsed_csv} > {log} 2>&1"


rule write_experiment_metadata:
    output:
        metadata=str(BASE_DIR / "metadata" / "{experiment_id}" / "experiment.json"),
    log:
        str(BASE_DIR / "logs" / "{experiment_id}" / "write_experiment_metadata.log"),
    params:
        config_file=str(REPO_ROOT / "config.yml"),
        base_dir=str(BASE_DIR),
        experiment_json=lambda wildcards: json.dumps(experiment_from_wildcards(wildcards), sort_keys=True),
        experiment_mode=WORKFLOW_CONFIG["experiment_mode"],
    shell:
        ".venv/bin/python workflow/scripts/write_experiment_metadata.py "
        "--config-file {params.config_file} "
        "--base-dir {params.base_dir} "
        "--experiment-json '{params.experiment_json}' "
        "--experiment-mode {params.experiment_mode} "
        "--output-file {output.metadata} > {log} 2>&1"


rule analyze:
    input:
        parsed_csvs=ANALYSIS_INPUTS,
    output:
        analysis_records=ANALYSIS_OUTPUTS["analysis_records"],
        sample_statistics=ANALYSIS_OUTPUTS["sample_statistics"],
        metric_comparisons=ANALYSIS_OUTPUTS["metric_comparisons"],
        top_regressions=ANALYSIS_OUTPUTS["top_regressions"],
        top_improvements=ANALYSIS_OUTPUTS["top_improvements"],
        analysis_summary=ANALYSIS_OUTPUTS["analysis_summary"],
    log:
        str(BASE_DIR / "logs" / "_analysis" / "analyze.log"),
    params:
        base_dir=str(BASE_DIR),
        output_dir=str(ANALYSIS_DIR),
        threshold_percent=WORKFLOW_CONFIG["analysis"]["change_threshold_percent"],
        min_samples=WORKFLOW_CONFIG["analysis"]["min_samples"],
        input_args=lambda wildcards, input: " ".join(
            f"--input-file {shlex.quote(path)}" for path in input.parsed_csvs
        ),
    shell:
        ".venv/bin/python workflow/scripts/analyze.py "
        "--base-dir {params.base_dir} "
        "{params.input_args} "
        "--output-dir {params.output_dir} "
        "--threshold-percent {params.threshold_percent} "
        "--min-samples {params.min_samples} > {log} 2>&1"


rule generate_report:
    input:
        analysis_records=ANALYSIS_OUTPUTS["analysis_records"],
        sample_statistics=ANALYSIS_OUTPUTS["sample_statistics"],
        metric_comparisons=ANALYSIS_OUTPUTS["metric_comparisons"],
        top_regressions=ANALYSIS_OUTPUTS["top_regressions"],
        top_improvements=ANALYSIS_OUTPUTS["top_improvements"],
        analysis_summary=ANALYSIS_OUTPUTS["analysis_summary"],
    output:
        html=ANALYSIS_REPORT,
    log:
        str(BASE_DIR / "logs" / "_analysis" / "generate_report.log"),
    params:
        analysis_dir=str(ANALYSIS_DIR),
    shell:
        ".venv/bin/python workflow/scripts/generate_report_cli.py "
        "--analysis-dir {params.analysis_dir} "
        "--output-html {output.html} > {log} 2>&1"
