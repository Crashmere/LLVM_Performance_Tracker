{% macro figure_section(figure, eyebrow="Chart", action_href="", action_label="") -%}
<section class="panel chart-panel">
  <div class="section-heading">
    <p class="eyebrow">{{ eyebrow }}</p>
    <h2>{{ figure.title }}</h2>
    <p class="muted">{{ figure.description }}</p>
    {% if action_href and action_label %}
    <p class="action-link"><a href="{{ action_href }}">{{ action_label }}</a></p>
    {% endif %}
  </div>
  {{ figure.html | safe }}
</section>
{%- endmacro %}

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>LLVM Performance Analysis Report</title>
  <style>{{ css | safe }}</style>
</head>
<body>
  <main>
    <section class="hero">
      <p class="eyebrow">Snakemake analysis report</p>
      <h1>LLVM Performance Analysis</h1>
      <p>
        This report summarizes all retained parsed benchmark results under <code>auto/parsed</code>.
        To exclude an old result from analysis, remove the unwanted output from <code>auto/</code> and rerun the workflow.
      </p>
      <p class="muted">Generated at {{ overview.generated_at }}</p>
    </section>

    <nav class="report-nav" aria-label="Report sections">
      <span class="nav-indicator" aria-hidden="true"></span>
      {% for item in nav_items %}
      <a href="{{ item.href }}">{{ item.label }}</a>
      {% endfor %}
    </nav>

    <section class="panel" id="overview">
      <div class="section-heading">
        <p class="eyebrow">Overview</p>
        <h2>Analysis Coverage</h2>
        <p class="muted">Start here to understand which retained runs are included before looking at version trends.</p>
      </div>
      <div class="cards">
        {% for card in overview.cards %}
        <div class="card">
          <span>{{ card.title }}</span>
          <strong>{{ card.value }}</strong>
          <em>{{ card.detail }}</em>
        </div>
        {% endfor %}
      </div>
      <div class="note">
        <p>
          Threshold: <strong>{{ overview.change_threshold_percent }}%</strong>.
          Minimum observations for reliable evidence: <strong>{{ overview.min_samples }}</strong>.
        </p>
        <p>Comparison scope: LLVM/compiler versions are compared only within the same suite, suite version, test, and metric.</p>
        <p>Compiler versions: {{ overview.compiler_versions }}</p>
        <p>Suite versions: {{ overview.suite_versions }}</p>
        <p>Labels: {{ overview.labels }}</p>
      </div>
      <div class="pill-row">
        {% for pill in overview.classification_pills %}
        <span class="pill {{ pill.kind }}">{{ pill.label }}</span>
        {% endfor %}
      </div>
      <div class="embedded-chart">
        <h3>{{ classification_figure.title }}</h3>
        <p class="muted">{{ classification_figure.description }}</p>
        {{ classification_figure.html | safe }}
      </div>
      <div class="subsection">
        <h3>Official And RAJA Summary</h3>
        <p class="muted">
          These cards summarize suite-level coverage. Detailed suite contribution is shown on demand from the LLVM version pair matrix below.
        </p>
        <div class="suite-grid">
          {% if suite_cards %}
          {% for suite in suite_cards %}
          <article class="suite-card">
            <h3>{{ suite.name }}</h3>
            <p class="muted">Metrics: {{ suite.metrics }}</p>
            <div class="mini-cards">
              {% for card in suite.cards %}
              <div class="card">
                <span>{{ card.title }}</span>
                <strong>{{ card.value }}</strong>
                <em>{{ card.detail }}</em>
              </div>
              {% endfor %}
            </div>
          </article>
          {% endfor %}
          {% else %}
          <p class="muted">No suite data available.</p>
          {% endif %}
        </div>
      </div>
    </section>

    <section class="panel chart-panel" id="trends">
      <div class="section-heading">
        <p class="eyebrow">Trends</p>
        <h2>{{ compiler_pair_figure.title }}</h2>
        <p class="muted">{{ compiler_pair_figure.description }}</p>
        <p class="muted">
          Use this view to find which LLVM version pair and metric changed most clearly.
          Click a cell or row to reveal suite-level contribution for that version pair.
        </p>
      </div>
      {{ compiler_pair_figure.html | safe }}
      <div class="drilldown-panel" id="suite-drilldown">
        <div class="section-heading compact-heading">
          <p class="eyebrow">Suite drilldown</p>
          <h3>Suite Contribution For Selected LLVM Version Pair</h3>
          <p class="muted">
            This area stays quiet until a version pair is selected. It then shows whether the trend is mostly from Official, RAJA, or both.
          </p>
        </div>
        {% if suite_drilldown_figures %}
        <label class="drilldown-select-label">LLVM version pair
          <select data-suite-drilldown-select>
            <option value="">Select a version pair...</option>
            {% for figure in suite_drilldown_figures %}
            <option value="{{ figure.compiler_pair }}">{{ figure.compiler_pair }}</option>
            {% endfor %}
          </select>
        </label>
        <div class="drilldown-placeholder" data-suite-drilldown-placeholder>
          Click any cell in the LLVM Version Pair Trend Matrix or use the selector above to reveal the corresponding suite contribution.
        </div>
        {% for figure in suite_drilldown_figures %}
        <article class="suite-drilldown" data-suite-drilldown data-compiler-pair="{{ figure.compiler_pair }}" hidden>
          <div class="section-heading compact-heading">
            <h3>{{ figure.title }}</h3>
            <p class="muted">{{ figure.description }}</p>
          </div>
          {{ figure.html | safe }}
        </article>
        {% endfor %}
        {% else %}
        <p class="muted">No suite drilldown data available.</p>
        {% endif %}
      </div>
    </section>

    <section class="panel" id="top-changes">
      <div class="section-heading">
        <p class="eyebrow">Priority list</p>
        <h2>Top LLVM Version Regressions And Improvements</h2>
        <p class="muted">
          Positive normalized change means the candidate LLVM version is better; negative means regression.
          Suite versions are fixed within each comparison, and suite information is shown in the chart labels and hover.
        </p>
      </div>
      <div class="chart-panel embedded-chart">
        {{ largest_changes_figure.html | safe }}
      </div>
      <div class="split">
        <div>
          <h3>Top Regressions</h3>
          <p><a href="{{ csv_links['top_regressions.csv'] }}">Open CSV</a></p>
          {% set table = top_regressions_table %}
          {% include "partials/table.html.j2" %}
        </div>
        <div>
          <h3>Top Improvements</h3>
          <p><a href="{{ csv_links['top_improvements.csv'] }}">Open CSV</a></p>
          {% set table = top_improvements_table %}
          {% include "partials/table.html.j2" %}
        </div>
      </div>
    </section>

    <section class="panel" id="noise">
      <div class="section-heading">
        <p class="eyebrow">Noise and confidence</p>
        <h2>Sample Stability</h2>
        <p class="muted">
          High CV values identify noisy tests. The chart uses a zoomed x-axis because the top CV values are often very close.
          Use this section before treating candidate changes as strong evidence.
        </p>
      </div>
      <div class="chart-panel embedded-chart">
        {{ sample_noise_figure.html | safe }}
      </div>
      <div class="subsection">
        <h3>Sample Statistics</h3>
        <p><a href="{{ csv_links['sample_statistics.csv'] }}">Open full CSV</a></p>
        {% set table = sample_table %}
        {% include "partials/table.html.j2" %}
      </div>
    </section>

    <section class="panel" id="data">
      <div class="section-heading">
        <p class="eyebrow">Data</p>
        <h2>Detailed Tables</h2>
        <p class="muted">
          Tables are the verification layer behind the charts. Use filters to narrow by suite, metric, compiler pair, classification, and evidence.
        </p>
      </div>
      <div class="subsection" id="comparisons">
        <h3>Metric Comparisons Across LLVM Versions</h3>
        <p class="muted">
          Comparisons keep suite version fixed and vary LLVM/compiler version.
          The table is capped at 500 highest-change rows in HTML; the full CSV remains available.
        </p>
        <p><a href="{{ csv_links['metric_comparisons.csv'] }}">Open full CSV</a></p>
        {% set table = comparison_table %}
        {% include "partials/table.html.j2" %}
      </div>
      <div class="subsection" id="details">
        <h3>Analysis Record Preview</h3>
        <p class="muted">Only the first 200 rows are embedded to keep the HTML manageable.</p>
        <p><a href="{{ csv_links['analysis_records.csv'] }}">Open full CSV</a></p>
        {% set table = detail_table %}
        {% include "partials/table.html.j2" %}
      </div>
    </section>
  </main>
  <script>{{ javascript | safe }}</script>
</body>
</html>
